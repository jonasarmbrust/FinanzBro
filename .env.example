# FinanzBro Konfiguration
# Kopiere diese Datei als .env und trage deine Werte ein:
#   copy .env.example .env

# Financial Modeling Prep API Key (kostenlos: https://financialmodelingprep.com)
FMP_API_KEY=your_fmp_api_key_here

# Stocknear Login (optional - für AI Scores)
STOCKNEAR_EMAIL=
STOCKNEAR_PASSWORD=

# Alpha Vantage API Key (kostenlos: https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=

# Finnhub (Echtzeit-Kurse via WebSocket, kostenlos: https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Parqet Connect API (OAuth2)
# Registriere eine App auf https://developer.parqet.com
PARQET_CLIENT_ID=your_parqet_client_id
PARQET_CLIENT_SECRET=your_parqet_client_secret
PARQET_ACCESS_TOKEN=
PARQET_REFRESH_TOKEN=
PARQET_PORTFOLIO_ID=your_portfolio_id

# Parqet CSV Export Pfad (Fallback, relativ zum Projektverzeichnis)
PARQET_PORTFOLIO_CSV=portfolio.csv

# Server Konfiguration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Scheduler (tägliche Aktualisierung, Format: HH:MM)
DAILY_REFRESH_TIME=06:00

# Analyse-Zeiten (komma-separiert, HH:MM Format)
# Full-Analyse um DAILY_REFRESH_TIME, Mid-Analysen zu weiteren Zeiten
ANALYSIS_TIMES=06:00,13:00,20:00

# Telegram Bot (für tägliche AI-Reports)
# 1) Erstelle Bot via @BotFather auf Telegram → /newbot
# 2) Chat-ID: Sende dem Bot eine Nachricht, dann https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Gemini API Key (für AI-Research, optional)
# Kostenlos: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# AI Finance Agent - tägliche Report-Zeit (nach dem 06:00 Refresh)
AI_AGENT_TIME=16:30
